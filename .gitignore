# Rust build output
/target/
# Note: Cargo.lock is intentionally committed for reproducibility (this is not a published library)

# Python artifacts
__pycache__/
*.py[cod]
*.so
*.pyd
*.egg-info/
dist/
*.whl
.venv/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
# track source notebooks; exclude generated/executed copies
!notebooks/noprop_ternary_colab_free_tier.ipynb
!notebooks/noprop_ternary_scale_runs.ipynb
!notebooks/.gitkeep
# platform-specific parallel notebooks
!notebooks/platforms/*.ipynb

# L3 snapshot cache (runtime data, not source)
/tmp/drex_l3/
drex_l3/
*.snap
*.meta
journal.ndjson

# Model checkpoints (large binaries — store externally)
*.pt
*.safetensors
results/wave*/checkpoints/

# IDE
.idea/
.vscode/
*.swp
